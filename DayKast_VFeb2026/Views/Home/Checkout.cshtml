@{
    ViewBag.Title = "Ödeme";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}
@Styles.Render("~/Content/css")
<div class="checkout-page">
    <!-- SOL: SİPARİŞ ÖZETİ -->
    <div class="checkout-left">
        <div class="checkout-card">
            <h3><i class="fas fa-shopping-bag"></i> Sipariş Özeti</h3>
            <div id="checkoutItems"></div>
            <div class="checkout-summary">
                <div class="summary-row">
                    <span>Ara Toplam</span>
                    <span id="subtotalPrice">₺0,00</span>
                </div>
                <div class="summary-row">
                    <span>Kargo</span>
                    <span style="color:#27ae60;">Ücretsiz</span>
                </div>
                <hr />
                <div class="summary-row total">
                    <span>Toplam</span>
                    <strong id="checkoutTotal">₺0,00</strong>
                </div>
            </div>
        </div>
    </div>

    <!-- SAĞ: ÖDEME FORMU -->
    <div class="checkout-right">
        <div class="checkout-card">
            <h3><i class="fas fa-credit-card"></i> Kart Bilgileri</h3>
            <!-- Kayıtlı Kartlar -->
            <div id="savedCardsSection" style="display:none; margin-bottom:20px;">
                <label style="display:block; font-size:13px; font-weight:700; color:#555; margin-bottom:10px;">
                    <i class="fas fa-wallet" style="color:#667eea; margin-right:6px;"></i> Kayıtlı Kartlarım
                </label>
                <div id="savedCardsList" style="display:flex; flex-direction:column; gap:8px;"></div>
                <label class="saved-card-option" style="margin-top:8px;" id="newCardOption">
                    <input type="radio" name="savedCard" value="new" checked />
                    <div class="sco-content">
                        <div class="sco-icon" style="background:linear-gradient(135deg,#e8e8e8,#ccc);">
                            <i class="fas fa-plus" style="color:#888;"></i>
                        </div>
                        <div class="sco-info">
                            <span class="sco-label">Yeni Kart ile Öde</span>
                            <span class="sco-detail">Kart bilgilerini manuel girin</span>
                        </div>
                    </div>
                </label>
            </div>

            <!-- Kart Görseli -->
            <div class="credit-card-visual" id="cardVisual">
                <div class="card-chip"></div>
                <div class="card-number" id="cardDisplayNumber">•••• •••• •••• ••••</div>
                <div class="card-bottom">
                    <div>
                        <small>KART SAHİBİ</small>
                        <div id="cardDisplayName">AD SOYAD</div>
                    </div>
                    <div>
                        <small>SON KUL. TARİHİ</small>
                        <div id="cardDisplayExpiry">MM/YY</div>
                    </div>
                </div>
            </div>

            <!-- Kart Formu -->
            <div class="card-form" id="cardFormFields">
                <div class="form-group">
                    <label>Kart Üzerindeki İsim</label>
                    <input type="text" id="cardName" placeholder="Ad Soyad" maxlength="50" />
                </div>
                <div class="form-group">
                    <label>Kart Numarası</label>
                    <input type="text" id="cardNumber" placeholder="0000 0000 0000 0000" maxlength="19" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Son Kullanma Tarihi</label>
                        <input type="text" id="cardExpiry" placeholder="AA/YY" maxlength="5" />
                    </div>
                    <div class="form-group">
                        <label>CVV</label>
                        <input type="text" id="cardCvv" placeholder="•••" maxlength="3" />
                    </div>
                </div>
            </div>
        </div>

        <!-- TAKSİT SEÇENEKLERİ -->
        <div class="checkout-card">
            <h3><i class="fas fa-list-ol"></i> Ödeme Seçenekleri</h3>
            <div class="installment-options">
                <label class="installment-option selected">
                    <input type="radio" name="installment" value="1" checked />
                    <div class="option-content">
                        <span class="option-label">Peşin</span>
                        <span class="option-price" id="installPrice1">₺0,00</span>
                    </div>
                </label>
                <label class="installment-option">
                    <input type="radio" name="installment" value="3" />
                    <div class="option-content">
                        <span class="option-label">3 Taksit</span>
                        <span class="option-price" id="installPrice3">₺0,00 × 3</span>
                    </div>
                </label>
                <label class="installment-option">
                    <input type="radio" name="installment" value="6" />
                    <div class="option-content">
                        <span class="option-label">6 Taksit</span>
                        <span class="option-price" id="installPrice6">₺0,00 × 6</span>
                    </div>
                </label>
                <label class="installment-option">
                    <input type="radio" name="installment" value="9" />
                    <div class="option-content">
                        <span class="option-label">9 Taksit</span>
                        <span class="option-price" id="installPrice9">₺0,00 × 9</span>
                    </div>
                </label>
            </div>
        </div>

        <!-- ÖDEME BUTONU -->
        <button class="btn-pay" id="btnPay" onclick="placeOrder()">
            <i class="fas fa-lock"></i> Ödemeyi Tamamla
        </button>
    </div>
</div>



<script>
    (function () {
        var cart = JSON.parse(localStorage.getItem('daykast_cart') || '[]');

        if (cart.length === 0) {
            window.location.href = '@Url.Action("Index", "Home")';
            return;
        }

        var container = document.getElementById('checkoutItems');
        var total = 0;

        cart.forEach(function (item) {
            var lineTotal = item.price * item.qty;
            total += lineTotal;

            var div = document.createElement('div');
            div.className = 'checkout-item';
            div.innerHTML =
                '<div class="checkout-item-icon"><i class="fas fa-box"></i></div>' +
                '<div class="checkout-item-info">' +
                    '<h4>' + item.name + '</h4>' +
                    '<small>' + item.qty + ' adet × ₺' + item.price.toFixed(2) + '</small>' +
                '</div>' +
                '<div class="checkout-item-price">₺' + lineTotal.toFixed(2) + '</div>';
            container.appendChild(div);
        });

        document.getElementById('subtotalPrice').textContent = '₺' + total.toFixed(2);
        document.getElementById('checkoutTotal').textContent = '₺' + total.toFixed(2);

        // Taksit
        document.getElementById('installPrice1').textContent = '₺' + total.toFixed(2);
        document.getElementById('installPrice3').textContent = '₺' + (total / 3).toFixed(2) + ' × 3';
        document.getElementById('installPrice6').textContent = '₺' + (total / 6).toFixed(2) + ' × 6';
        document.getElementById('installPrice9').textContent = '₺' + (total / 9).toFixed(2) + ' × 9';

        // Taksit seçim
        document.querySelectorAll('.installment-option').forEach(function (opt) {
            opt.addEventListener('click', function () {
                document.querySelectorAll('.installment-option').forEach(function (o) { o.classList.remove('selected'); });
                opt.classList.add('selected');
                opt.querySelector('input').checked = true;
            });
        });

        // Kart numarası formatlama ve görsel güncelleme
        document.getElementById('cardNumber').addEventListener('input', function () {
            var val = this.value.replace(/\D/g, '').substring(0, 16);
            var formatted = val.replace(/(.{4})/g, '$1 ').trim();
            this.value = formatted;
            document.getElementById('cardDisplayNumber').textContent = formatted || '•••• •••• •••• ••••';
        });

        document.getElementById('cardName').addEventListener('input', function () {
            document.getElementById('cardDisplayName').textContent = this.value.toUpperCase() || 'AD SOYAD';
        });

        document.getElementById('cardExpiry').addEventListener('input', function () {
            var val = this.value.replace(/\D/g, '').substring(0, 4);
            if (val.length >= 2) val = val.substring(0, 2) + '/' + val.substring(2);
            this.value = val;
            document.getElementById('cardDisplayExpiry').textContent = val || 'MM/YY';
        });

        document.getElementById('cardCvv').addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').substring(0, 3);
        });
    })();

    // ========== KAYITLI KARTLAR ==========
    (function loadSavedCards() {
        var cards = JSON.parse(localStorage.getItem('daykast_cards') || '[]');
        if (cards.length === 0) return;

        var section = document.getElementById('savedCardsSection');
        var list = document.getElementById('savedCardsList');
        section.style.display = 'block';

        cards.forEach(function (card, idx) {
            var masked = '**** **** **** ' + card.number.slice(-4);
            var label = document.createElement('label');
            label.className = 'saved-card-option';
            label.innerHTML =
                '<input type="radio" name="savedCard" value="' + idx + '" />' +
                '<div class="sco-content">' +
                    '<div class="sco-icon"><i class="fas fa-credit-card"></i></div>' +
                    '<div class="sco-info">' +
                        '<span class="sco-label">' + (card.label || card.name) + '</span>' +
                        '<span class="sco-detail">' + masked + ' • ' + card.expiry + '</span>' +
                    '</div>' +
                '</div>';
            list.appendChild(label);
        });

        // Kart seçim olayları
        document.querySelectorAll('input[name="savedCard"]').forEach(function (radio) {
            radio.addEventListener('change', function () {
                document.querySelectorAll('.saved-card-option').forEach(function (o) { o.classList.remove('selected'); });
                this.closest('.saved-card-option').classList.add('selected');

                var formFields = document.getElementById('cardFormFields');
                if (this.value === 'new') {
                    // Manuel giriş
                    formFields.style.display = 'block';
                    document.getElementById('cardName').value = '';
                    document.getElementById('cardNumber').value = '';
                    document.getElementById('cardExpiry').value = '';
                    document.getElementById('cardCvv').value = '';
                    document.getElementById('cardDisplayNumber').textContent = '•••• •••• •••• ••••';
                    document.getElementById('cardDisplayName').textContent = 'AD SOYAD';
                    document.getElementById('cardDisplayExpiry').textContent = 'MM/YY';
                } else {
                    // Kayıtlı kart seçildi
                    var c = cards[parseInt(this.value)];
                    var formatted = c.number.replace(/(.{4})/g, '$1 ').trim();
                    document.getElementById('cardName').value = c.name;
                    document.getElementById('cardNumber').value = formatted;
                    document.getElementById('cardExpiry').value = c.expiry;
                    document.getElementById('cardCvv').value = '';
                    document.getElementById('cardDisplayNumber').textContent = formatted;
                    document.getElementById('cardDisplayName').textContent = c.name.toUpperCase();
                    document.getElementById('cardDisplayExpiry').textContent = c.expiry;
                    // CVV hariç formu gizle, sadece CVV'yi göster
                    formFields.style.display = 'block';
                    document.getElementById('cardCvv').focus();
                }
            });
        });

        // Varsayılan olarak "Yeni Kart" seçili
        document.getElementById('newCardOption').classList.add('selected');
    })();

    function placeOrder() {
        var cardName = document.getElementById('cardName').value.trim();
        var cardNumber = document.getElementById('cardNumber').value.replace(/\s/g, '');
        var cardExpiry = document.getElementById('cardExpiry').value.trim();
        var cardCvv = document.getElementById('cardCvv').value.trim();

        if (!cardName || cardNumber.length < 16 || cardExpiry.length < 5 || cardCvv.length < 3) {
            alert('Lütfen kart bilgilerini eksiksiz doldurunuz.');
            return;
        }

        // Kayıtlı kart seçildiyse modal gösterme, direkt devam et
        var selectedSaved = document.querySelector('input[name="savedCard"]:checked');
        if (selectedSaved && selectedSaved.value !== 'new') {
            executePlaceOrder();
            return;
        }

        // Kart zaten kayıtlıysa modal gösterme
        var existingCards = JSON.parse(localStorage.getItem('daykast_cards') || '[]');
        var alreadySaved = existingCards.some(function(c) {
            return c.number === cardNumber;
        });
        if (alreadySaved) {
            executePlaceOrder();
            return;
        }

        // Modal göster
        document.getElementById('saveCardModal').style.display = 'flex';
    }

    function saveCardAndPay() {
        var cardName = document.getElementById('cardName').value.trim();
        var cardNumber = document.getElementById('cardNumber').value.replace(/\s/g, '');
        var cardExpiry = document.getElementById('cardExpiry').value.trim();

        var cards = JSON.parse(localStorage.getItem('daykast_cards') || '[]');
        cards.push({
            name: cardName,
            number: cardNumber,
            expiry: cardExpiry,
            label: cardName
        });
        localStorage.setItem('daykast_cards', JSON.stringify(cards));

        document.getElementById('saveCardModal').style.display = 'none';
        executePlaceOrder();
    }

    function skipSaveAndPay() {
        document.getElementById('saveCardModal').style.display = 'none';
        executePlaceOrder();
    }

    function executePlaceOrder() {
        var btn = document.getElementById('btnPay');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> İşleniyor...';

        var cart = JSON.parse(localStorage.getItem('daykast_cart') || '[]');
        var total = cart.reduce(function (s, i) { return s + (i.price * i.qty); }, 0);

        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        var xhr = new XMLHttpRequest();
        xhr.open('POST', '@Url.Action("PlaceOrder", "Home")', true);
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.onreadystatechange = function () {
            if (xhr.readyState === 4) {
                if (xhr.status === 200) {
                    var res = JSON.parse(xhr.responseText);
                    if (res.success) {
                        localStorage.removeItem('daykast_cart');
                        window.location.href = '@Url.Action("OrderSuccess", "Home")?orderId=' + res.orderId + '&itemCount=' + res.itemCount;
                    } else {
                        alert(res.message || 'Bir hata oluştu.');
                        btn.disabled = false;
                        btn.innerHTML = '<i class="fas fa-lock"></i> Ödemeyi Tamamla';
                    }
                } else {
                    alert('Sunucu hatası. Lütfen tekrar deneyiniz.');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-lock"></i> Ödemeyi Tamamla';
                }
            }
        };
        xhr.send('cartData=' + encodeURIComponent(JSON.stringify(cart)) + '&totalAmount=' + total + '&__RequestVerificationToken=' + encodeURIComponent(token));
    }
</script>

<!-- KARTI KAYDET MODAL -->
<div id="saveCardModal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:#fff; border-radius:16px; padding:36px 32px; max-width:420px; width:90%; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3); animation:saveCardModalIn 0.3s ease;">
        <div style="width:64px; height:64px; margin:0 auto 16px; background:linear-gradient(135deg,#eef2ff,#e0e7ff); border-radius:50%; display:flex; align-items:center; justify-content:center;">
            <i class="fas fa-credit-card" style="font-size:28px; color:#667eea;"></i>
        </div>
        <h3 style="margin:0 0 8px; font-size:18px; color:#333; font-weight:700;">Kartı Kaydetmek İster Misiniz?</h3>
        <p style="margin:0 0 24px; font-size:14px; color:#888; line-height:1.6;">Kart bilgileriniz güvenli bir şekilde kaydedilerek gelecek alışverişlerinizde hızlıca ödeme yapabilirsiniz.</p>
        <div style="display:flex; flex-direction:column; gap:10px;">
            <button onclick="saveCardAndPay()" style="width:100%; padding:12px 24px; background:linear-gradient(135deg,#667eea,#764ba2); color:#fff; border:none; border-radius:10px; font-size:15px; font-weight:600; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; transition:all 0.3s;">
                <i class="fas fa-save"></i> Kartı Kaydet ve Öde
            </button>
            <button onclick="skipSaveAndPay()" style="width:100%; padding:12px 24px; background:#f8f9fa; color:#555; border:1px solid #e0e0e0; border-radius:10px; font-size:14px; font-weight:500; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; transition:all 0.3s;">
                <i class="fas fa-arrow-right"></i> Kaydetmeden Devam Et
            </button>
        </div>
    </div>
</div> 

@Html.AntiForgeryToken()
