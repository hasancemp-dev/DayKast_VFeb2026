@{
    ViewBag.Title = "Hakkımızda";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<section class="page-hero">
    <div class="page-hero-content">
        <h1><i class="fas fa-building"></i> Hakkımızda</h1>
        <p>DayKast'ı yakından tanıyın</p>
    </div>
</section>

<div class="about-page">

    <!-- TARİHÇE -->
    <div class="about-section">
        <div class="about-section-icon history-icon">
            <i class="fas fa-landmark"></i>
        </div>
        <div class="about-section-content">
            <h2>Tarihçemiz</h2>
            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-year">2020</div>
                    <div class="timeline-text">
                        <h4>Kuruluş</h4>
                        <p>DayKast, Bursa'da küçük bir ekip tarafından e-ticaret alanında yenilikçi çözümler sunmak amacıyla kuruldu. İlk günden itibaren müşteri memnuniyetini ön planda tutarak sektörde fark yaratmayı hedefledik.</p>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-year">2022</div>
                    <div class="timeline-text">
                        <h4>Büyüme</h4>
                        <p>Ürün yelpazemizi genişleterek binlerce ürünle müşterilerimize hizmet vermeye başladık. Türkiye genelinde hızlı teslimat ağımızı kurduk ve ekibimizi 50 kişiye çıkardık.</p>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-year">2024</div>
                    <div class="timeline-text">
                        <h4>Dijital Dönüşüm</h4>
                        <p>Yapay zeka destekli ürün önerileri, kişiselleştirilmiş alışveriş deneyimi ve gelişmiş lojistik altyapımızla sektördeki lider konumumuzu pekiştirdik.</p>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-year">2026</div>
                    <div class="timeline-text">
                        <h4>Bugün</h4>
                        <p>200'den fazla çalışanımız, 10.000+ ürün çeşidimiz ve milyonlarca mutlu müşterimizle Türkiye'nin en güvenilir e-ticaret platformlarından biri olarak hizmet vermeye devam ediyoruz.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- VİZYON & MİSYON -->
    <div class="vm-grid">
        <div class="vm-card vision-card">
            <div class="vm-icon">
                <i class="fas fa-eye"></i>
            </div>
            <h3>Vizyonumuz</h3>
            <p>Teknoloji ve inovasyonu kullanarak, herkesin güvenle ve keyifle alışveriş yapabileceği, Türkiye'nin lider dijital ticaret platformu olmak. Müşterilerimize sadece ürün değil, benzersiz bir deneyim sunarak e-ticarette global standartları belirleyen bir marka haline gelmek.</p>
            <div class="vm-highlight">
                <i class="fas fa-quote-left"></i>
                Geleceğin alışverişini bugünden şekillendiriyoruz.
            </div>
        </div>
        <div class="vm-card mission-card">
            <div class="vm-icon">
                <i class="fas fa-bullseye"></i>
            </div>
            <h3>Misyonumuz</h3>
            <p>Müşterilerimize en kaliteli ürünleri en uygun fiyatlarla sunmak, hızlı ve güvenilir teslimat sağlamak, satış sonrası destek ile tam müşteri memnuniyeti oluşturmak. Çalışanlarımıza değer vererek, tedarikçilerimizle sürdürülebilir ilişkiler kurarak sektörde güven ve kalite odaklı büyümek.</p>
            <div class="vm-highlight">
                <i class="fas fa-quote-left"></i>
                Her siparişte güven, her ürünte kalite.
            </div>
        </div>
    </div>

    <!-- DEĞERLER -->
    <div class="values-section">
        <h2><i class="fas fa-heart" style="color:#f56565;"></i> Değerlerimiz</h2>
        <div class="values-grid">
            <div class="value-item">
                <div class="value-icon"><i class="fas fa-handshake"></i></div>
                <h4>Güven</h4>
                <p>Müşterilerimizle şeffaf ve dürüst ilişkiler kuruyoruz.</p>
            </div>
            <div class="value-item">
                <div class="value-icon"><i class="fas fa-rocket"></i></div>
                <h4>İnovasyon</h4>
                <p>Sürekli gelişim ve yenilikçi çözümler üretiyoruz.</p>
            </div>
            <div class="value-item">
                <div class="value-icon"><i class="fas fa-users"></i></div>
                <h4>Takım Ruhu</h4>
                <p>Birlikte çalışarak daha güçlü sonuçlar elde ediyoruz.</p>
            </div>
            <div class="value-item">
                <div class="value-icon"><i class="fas fa-leaf"></i></div>
                <h4>Sürdürülebilirlik</h4>
                <p>Çevreye duyarlı ve sorumlu iş uygulamaları geliştiriyoruz.</p>
            </div>
        </div>
    </div>
</div>

<style>
    .page-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 50px 20px; text-align: center; color: #fff;
    }
    .page-hero h1 { font-size: 2rem; font-weight: 800; margin: 0 0 8px; }
    .page-hero h1 i { margin-right: 10px; }
    .page-hero p { margin: 0; opacity: 0.85; font-size: 1.05rem; }

    .about-page {
        max-width: 1100px; margin: 40px auto; padding: 0 20px;
    }

    /* TARİHÇE */
    .about-section {
        display: flex; gap: 30px; margin-bottom: 50px;
        background: #fff; border-radius: 16px; padding: 36px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    }
    .about-section-icon {
        width: 60px; height: 60px; border-radius: 16px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem;
    }
    .history-icon { background: #ede9fe; color: #7c3aed; }
    .about-section-content { flex: 1; }
    .about-section-content h2 { margin: 0 0 24px; font-size: 1.3rem; color: #333; }

    .timeline { position: relative; padding-left: 30px; }
    .timeline::before {
        content: ''; position: absolute; left: 6px; top: 8px; bottom: 8px;
        width: 3px; background: linear-gradient(to bottom, #667eea, #764ba2);
        border-radius: 3px;
    }
    .timeline-item {
        position: relative; margin-bottom: 28px; padding-left: 20px;
    }
    .timeline-item:last-child { margin-bottom: 0; }
    .timeline-item::before {
        content: ''; position: absolute; left: -27px; top: 6px;
        width: 12px; height: 12px; border-radius: 50%;
        background: #667eea; border: 3px solid #fff;
        box-shadow: 0 0 0 2px #667eea;
    }
    .timeline-year {
        font-size: 0.8rem; font-weight: 800; color: #667eea;
        background: #f5f3ff; display: inline-block; padding: 3px 12px;
        border-radius: 12px; margin-bottom: 6px;
    }
    .timeline-text h4 { margin: 0 0 4px; font-size: 1rem; color: #333; }
    .timeline-text p { margin: 0; font-size: 0.9rem; color: #666; line-height: 1.6; }

    /* VİZYON MİSYON */
    .vm-grid {
        display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 50px;
    }
    .vm-card {
        background: #fff; border-radius: 16px; padding: 32px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.07); text-align: center;
        transition: transform 0.3s;
    }
    .vm-card:hover { transform: translateY(-4px); }
    .vm-icon {
        width: 70px; height: 70px; border-radius: 50%; margin: 0 auto 18px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.6rem;
    }
    .vision-card .vm-icon { background: linear-gradient(135deg, #dbeafe, #ede9fe); color: #667eea; }
    .mission-card .vm-icon { background: linear-gradient(135deg, #d1fae5, #dbeafe); color: #059669; }
    .vm-card h3 { margin: 0 0 14px; font-size: 1.15rem; color: #333; }
    .vm-card p { font-size: 0.9rem; color: #666; line-height: 1.7; margin: 0 0 18px; }
    .vm-highlight {
        background: #f5f3ff; border-radius: 10px; padding: 14px 18px;
        font-size: 0.88rem; font-weight: 600; color: #667eea; font-style: italic;
    }
    .vm-highlight i { margin-right: 6px; opacity: 0.5; }

    /* DEĞERLER */
    .values-section {
        background: #fff; border-radius: 16px; padding: 36px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.07); text-align: center;
    }
    .values-section h2 { margin: 0 0 28px; font-size: 1.3rem; color: #333; }
    .values-section h2 i { margin-right: 8px; }
    .values-grid {
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
    }
    .value-item {
        padding: 24px 16px; border-radius: 14px;
        background: #fafbff; transition: transform 0.2s;
    }
    .value-item:hover { transform: translateY(-3px); }
    .value-icon {
        width: 50px; height: 50px; border-radius: 14px; margin: 0 auto 12px;
        display: flex; align-items: center; justify-content: center;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff; font-size: 1.2rem;
    }
    .value-item h4 { margin: 0 0 6px; font-size: 0.95rem; color: #333; }
    .value-item p { margin: 0; font-size: 0.82rem; color: #888; line-height: 1.5; }

    @@media (max-width: 768px) {
        .about-section { flex-direction: column; }
        .vm-grid { grid-template-columns: 1fr; }
        .values-grid { grid-template-columns: 1fr 1fr; }
    }
</style>
