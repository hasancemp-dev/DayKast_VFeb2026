@model List<DayKast_VFeb2026.Models.Products>
@{
    ViewBag.Title = "Favorilerim - DayKast";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    .favorites-container {
        max-width: 1200px;
        margin: 30px auto;
        padding: 0 20px;
    }
    .favorites-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
    }
    .favorites-header h1 {
        margin: 0;
        font-size: 24px;
        color: #333;
        font-weight: 700;
    }
    .favorites-header .fav-icon {
        width: 44px;
        height: 44px;
        background: linear-gradient(135deg, #fef2f0, #fde8e4);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: #e8553d;
    }
    .favorites-count {
        font-size: 14px;
        color: #999;
        margin-left: auto;
    }
    .favorites-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 20px;
    }
    .fav-card {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        transition: all 0.3s ease;
        position: relative;
    }
    .fav-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    }
    .fav-card-img {
        width: 100%;
        height: 200px;
        overflow: hidden;
        background: #f8f8f8;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .fav-card-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }
    .fav-card:hover .fav-card-img img {
        transform: scale(1.05);
    }
    .fav-card-img .no-img {
        font-size: 48px;
        color: #ddd;
    }
    .fav-card-body {
        padding: 16px;
    }
    .fav-card-brand {
        font-size: 11px;
        color: #667eea;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
        margin-bottom: 4px;
    }
    .fav-card-name {
        font-size: 14px;
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.4;
    }
    .fav-card-name a {
        color: inherit;
        text-decoration: none;
    }
    .fav-card-name a:hover {
        color: #667eea;
    }
    .fav-card-price {
        font-size: 18px;
        font-weight: 700;
        color: #e74c3c;
    }
    .fav-card-actions {
        display: flex;
        gap: 8px;
        margin-top: 12px;
    }
    .fav-card-actions .btn-detail {
        flex: 1;
        padding: 8px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border: none;
        border-radius: 8px;
        text-decoration: none;
        text-align: center;
        font-size: 13px;
        font-weight: 500;
        transition: all 0.3s;
    }
    .fav-card-actions .btn-detail:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }
    .fav-card-actions .btn-remove {
        width: 38px;
        height: 38px;
        border: 2px solid #e8553d;
        color: #e8553d;
        background: #fff;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        transition: all 0.3s;
        flex-shrink: 0;
    }
    .fav-card-actions .btn-remove:hover {
        background: #e8553d;
        color: #fff;
    }
    .favorites-empty {
        text-align: center;
        padding: 60px 20px;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .favorites-empty i {
        font-size: 64px;
        color: #ddd;
        margin-bottom: 16px;
    }
    .favorites-empty h3 {
        color: #999;
        margin: 0 0 8px;
        font-size: 18px;
    }
    .favorites-empty p {
        color: #bbb;
        font-size: 14px;
        margin: 0 0 20px;
    }
    .favorites-empty .btn-shop {
        display: inline-block;
        padding: 10px 28px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border-radius: 8px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.3s;
    }
    .favorites-empty .btn-shop:hover {
        opacity: 0.9;
    }
</style>

<div class="favorites-container">
    <div class="favorites-header">
        <div class="fav-icon"><i class="fas fa-heart"></i></div>
        <h1>Favorilerim</h1>
        <span class="favorites-count">@Model.Count ürün</span>
    </div>

    @if (Model.Any())
    {
        <div class="favorites-grid">
            @foreach (var product in Model)
            {
                var cover = product.ProductImages != null && product.ProductImages.Any()
                    ? (product.ProductImages.FirstOrDefault(pi => pi.IsCoverImage == true) ?? product.ProductImages.FirstOrDefault())
                    : null;

                <div class="fav-card" id="favCard-@product.ProductID">
                    <a href="@Url.Action("ProductDetail", "Home", new { id = product.ProductID })">
                        <div class="fav-card-img">
                            @if (cover != null)
                            {
                                <img src="@cover.ImagePath" alt="@product.ProductName" />
                            }
                            else
                            {
                                <i class="fas fa-box no-img"></i>
                            }
                        </div>
                    </a>
                    <div class="fav-card-body">
                        @if (product.Brands != null)
                        {
                            <div class="fav-card-brand">@product.Brands.BrandName</div>
                        }
                        <div class="fav-card-name">
                            <a href="@Url.Action("ProductDetail", "Home", new { id = product.ProductID })">@product.ProductName</a>
                        </div>
                        <div class="fav-card-price">₺@product.SalePrice.ToString("N2")</div>
                        <div class="fav-card-actions">
                            <a href="@Url.Action("ProductDetail", "Home", new { id = product.ProductID })" class="btn-detail">
                                <i class="fas fa-eye"></i> Görüntüle
                            </a>
                            <button class="btn-remove" title="Favorilerden Çıkar" onclick="removeFavorite(@product.ProductID)">
                                <i class="fas fa-heart-broken"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="favorites-empty">
            <i class="far fa-heart"></i>
            <h3>Favori listeniz boş</h3>
            <p>Beğendiğiniz ürünleri kalp simgesine tıklayarak favorilere ekleyin.</p>
            <a href="@Url.Action("Index", "Home")" class="btn-shop">
                <i class="fas fa-shopping-bag"></i> Alışverişe Başla
            </a>
        </div>
    }
</div>

@section scripts {
<script>
    function removeFavorite(productId) {
        $.ajax({
            url: '/Home/ToggleFavorite',
            type: 'POST',
            dataType: 'json',
            data: { productId: productId },
            success: function(res) {
                if (res && res.success && !res.isFavorite) {
                    var card = document.getElementById('favCard-' + productId);
                    if (card) {
                        card.style.transition = 'all 0.4s ease';
                        card.style.opacity = '0';
                        card.style.transform = 'scale(0.8)';
                        setTimeout(function() {
                            card.remove();
                            var remaining = document.querySelectorAll('.fav-card').length;
                            document.querySelector('.favorites-count').textContent = remaining + ' ürün';
                            var badge = document.getElementById('favBadge');
                            if (badge) {
                                badge.textContent = remaining;
                                badge.style.display = remaining > 0 ? 'flex' : 'none';
                            }
                            if (remaining === 0) {
                                location.reload();
                            }
                        }, 400);
                    }
                }
            },
            error: function() {
                location.reload();
            }
        });
    }
</script>
}
