<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - DayKast Yönetim Paneli</title>
    
    <!-- Admin Styles -->
    <link href="~/Content/AdminStyles.css" rel="stylesheet" />
    
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    @RenderSection("styles", required: false)
</head>
<body>
    <div class="admin-wrapper">
        <!-- Sidebar Navigation -->
        <aside class="admin-sidebar">
            <div class="sidebar-header">
                <h2>DayKast</h2>
                <span class="admin-badge">YÖNETİM PANELİ</span>
            </div>
            
            <ul class="sidebar-menu">
                <li>
                    <a href="@Url.Action("YonetimPaneli", "Admin")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "Admin" ? "active" : "")">
                        <i class="fas fa-tachometer-alt"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Products")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "Products" ? "active" : "")">
                        <i class="fas fa-box"></i>
                        <span>Ürün Yönetimi</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Categories")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "Categories" ? "active" : "")">
                        <i class="fas fa-tags"></i>
                        <span>Kategori Yönetimi</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Brands")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "Brands" ? "active" : "")">
                        <i class="fas fa-building"></i>
                        <span>Marka Yönetimi</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Suppliers")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "Suppliers" ? "active" : "")">
                        <i class="fas fa-truck"></i>
                        <span>Tedarikçi Yönetimi</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Members")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "Members" ? "active" : "")">
                        <i class="fas fa-users"></i>
                        <span>Üye Yönetimi</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Orders")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "Orders" ? "active" : "")">
                        <i class="fas fa-shopping-cart"></i>
                        <span>Sipariş Yönetimi</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Reports", "Admin")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Reports" ? "active" : "")">
                        <i class="fas fa-chart-bar"></i>
                        <span>Rapor İşlemleri</span>
                    </a>
                </li>
            </ul>
        </aside>

        <!-- Main Content Area -->
        <div class="admin-content">
            <!-- Top Header -->
            <header class="admin-header">
                <h1>@ViewBag.Title</h1>
                <div class="admin-user-info">
                    <a href="@Url.Action("Index", "Home")" class="btn-switch-site" title="Ana Siteye Git" style="display:inline-flex;align-items:center;justify-content:center;width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;font-size:0.9rem;text-decoration:none;transition:all 0.3s;box-shadow:0 3px 12px rgba(102,126,234,0.3);margin-right:12px;">
                        <i class="fas fa-rotate"></i>
                    </a>
                    <span><i class="fas fa-user-circle"></i> Yönetici</span>
                    <a href="@Url.Action("Logout", "Admin")" class="btn-logout">
                        <i class="fas fa-sign-out-alt"></i> Çıkış
                    </a>
                </div>
            </header>

            <!-- Main Content -->
            <main class="admin-main fade-in">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    @RenderSection("scripts", required: false)
    
    <script>
        // Mobile sidebar toggle (gelecekte eklenebilir)
        document.addEventListener('DOMContentLoaded', function() {
            // Aktif menü öğesini vurgula
            const currentPath = window.location.pathname;
            const menuLinks = document.querySelectorAll('.sidebar-menu a');
            
            menuLinks.forEach(link => {
                if (link.getAttribute('href') === currentPath) {
                    link.classList.add('active');
                }
            });
        });
    </script>
</body>
</html>
