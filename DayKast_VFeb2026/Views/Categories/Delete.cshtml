@model DayKast_VFeb2026.Models.Categories

@{
    ViewBag.Title = "Kategori Sil";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3><i class="fas fa-exclamation-triangle"></i> Bu kategoriyi silmek istediğinize emin misiniz?</h3>
<div>
    <h4>Kategori Bilgileri</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Kategori Adı</dt>
        <dd>@Html.DisplayFor(model => model.CategoryName)</dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-actions">
            <input type="submit" value="Sil" class="btn btn-danger" />
            @Html.ActionLink("İptal - Listeye Dön", "Index")
        </div>
    }
</div>
