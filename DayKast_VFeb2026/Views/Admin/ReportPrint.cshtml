@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.ReportTitle - DayKast Rapor</title>
    <style>
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            margin: 0;
            padding: 0;
            color: #333;
        }
        .print-toolbar {
            background: linear-gradient(135deg, #667eea, #764ba2);
            padding: 12px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .print-toolbar h3 {
            color: #fff;
            margin: 0;
            font-size: 1rem;
        }
        .print-toolbar-actions {
            display: flex;
            gap: 10px;
        }
        .print-toolbar-actions button {
            padding: 8px 20px;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            font-size: 0.85rem;
            transition: all 0.2s;
        }
        .btn-print {
            background: #fff;
            color: #667eea;
        }
        .btn-print:hover {
            background: #f0edff;
        }
        .btn-back {
            background: rgba(255,255,255,0.2);
            color: #fff;
        }
        .btn-back:hover {
            background: rgba(255,255,255,0.3);
        }
        .report-container {
            max-width: 1100px;
            margin: 20px auto;
            padding: 30px;
            background: #fff;
            box-shadow: 0 2px 20px rgba(0,0,0,0.08);
            border-radius: 12px;
        }
        .report-footer {
            text-align: center;
            padding: 20px;
            color: #aaa;
            font-size: 11px;
            margin-top: 30px;
            border-top: 1px solid #eee;
        }
        @@media print {
            .print-toolbar { display: none !important; }
            .report-container { box-shadow: none; margin: 0; padding: 10px; }
            body { margin: 0; }
        }
    </style>
</head>
<body>
    <div class="print-toolbar">
        <h3><i class="fas fa-file-alt"></i> @ViewBag.ReportTitle</h3>
        <div class="print-toolbar-actions">
            <button class="btn-back" onclick="window.history.back()">
                ← Geri Dön
            </button>
            <button class="btn-print" onclick="window.print()">
                🖨️ Yazdır / PDF Kaydet
            </button>
        </div>
    </div>

    <div class="report-container">
        @Html.Raw(ViewBag.ReportHtml)
    </div>

    <div class="report-footer">
        DayKast Yönetim Paneli - Rapor oluşturma tarihi: @DateTime.Now.ToString("dd.MM.yyyy HH:mm:ss")
    </div>
</body>
</html>
