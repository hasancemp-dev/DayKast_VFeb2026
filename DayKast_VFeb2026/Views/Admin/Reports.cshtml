@{
    ViewBag.Title = "Rapor İşlemleri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="reports-page">
    <div class="reports-header">
        <div class="reports-header-icon">
            <i class="fas fa-chart-bar"></i>
        </div>
        <div>
            <h2>Rapor İşlemleri</h2>
            <p>Veritabanından detaylı raporlar oluşturun. PDF veya Excel formatında indirebilirsiniz.</p>
        </div>
    </div>

    <div class="reports-grid">
        <!-- 1. ÜRÜN RAPORU -->
        <div class="report-card">
            <div class="report-card-header" style="background: linear-gradient(135deg, #667eea, #764ba2);">
                <div class="report-icon">
                    <i class="fas fa-box"></i>
                </div>
                <div class="report-badge">Rapor</div>
            </div>
            <div class="report-card-body">
                <h3>Ürün Raporu</h3>
                <p>En çok satan ürünler ve bu ürünleri alan müşterilerin şehir bazlı dağılımı.</p>
                <div class="report-meta">
                    <span><i class="fas fa-trophy"></i> Top 20 / Top 50</span>
                    <span><i class="fas fa-map-marker-alt"></i> Şehir Bazlı</span>
                </div>
            </div>
            <div class="report-card-footer">
                <div class="btn-dropdown-wrapper">
                    <button class="btn-report btn-pdf" onclick="toggleDropdown(this)">
                        <i class="fas fa-file-pdf"></i> PDF <i class="fas fa-caret-down"></i>
                    </button>
                    <div class="dropdown-menu">
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "products", subType = "top20", format = "pdf" })">
                            <i class="fas fa-star"></i> Top 20 (Şehir Bazlı)
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "products", subType = "top50", format = "pdf" })">
                            <i class="fas fa-crown"></i> Top 50 (Şehir Bazlı)
                        </a>
                    </div>
                </div>
                <div class="btn-dropdown-wrapper">
                    <button class="btn-report btn-excel" onclick="toggleDropdown(this)">
                        <i class="fas fa-file-excel"></i> Excel <i class="fas fa-caret-down"></i>
                    </button>
                    <div class="dropdown-menu">
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "products", subType = "top20", format = "excel" })">
                            <i class="fas fa-star"></i> Top 20 (Şehir Bazlı)
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "products", subType = "top50", format = "excel" })">
                            <i class="fas fa-crown"></i> Top 50 (Şehir Bazlı)
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. SİPARİŞ RAPORU -->
        <div class="report-card">
            <div class="report-card-header" style="background: linear-gradient(135deg, #f093fb, #f5576c);">
                <div class="report-icon">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <div class="report-badge">Rapor</div>
            </div>
            <div class="report-card-body">
                <h3>Sipariş Raporu</h3>
                <p>Siparişlerin üye, şehir ve ürün bazlı detaylı analizleri ve dağılımları.</p>
                <div class="report-meta">
                    <span><i class="fas fa-user"></i> Üye Bazlı</span>
                    <span><i class="fas fa-city"></i> Şehir Bazlı</span>
                    <span><i class="fas fa-box"></i> Ürün Bazlı</span>
                </div>
            </div>
            <div class="report-card-footer">
                <div class="btn-dropdown-wrapper">
                    <button class="btn-report btn-pdf" onclick="toggleDropdown(this)">
                        <i class="fas fa-file-pdf"></i> PDF <i class="fas fa-caret-down"></i>
                    </button>
                    <div class="dropdown-menu">
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "orders", subType = "member", format = "pdf" })">
                            <i class="fas fa-user"></i> Üye Bazlı
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "orders", subType = "city", format = "pdf" })">
                            <i class="fas fa-city"></i> Şehir Bazlı
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "orders", subType = "product", format = "pdf" })">
                            <i class="fas fa-box"></i> Ürün Bazlı
                        </a>
                    </div>
                </div>
                <div class="btn-dropdown-wrapper">
                    <button class="btn-report btn-excel" onclick="toggleDropdown(this)">
                        <i class="fas fa-file-excel"></i> Excel <i class="fas fa-caret-down"></i>
                    </button>
                    <div class="dropdown-menu">
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "orders", subType = "member", format = "excel" })">
                            <i class="fas fa-user"></i> Üye Bazlı
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "orders", subType = "city", format = "excel" })">
                            <i class="fas fa-city"></i> Şehir Bazlı
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "orders", subType = "product", format = "excel" })">
                            <i class="fas fa-box"></i> Ürün Bazlı
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. ÜYE RAPORU -->
        <div class="report-card">
            <div class="report-card-header" style="background: linear-gradient(135deg, #4facfe, #00f2fe);">
                <div class="report-icon">
                    <i class="fas fa-users"></i>
                </div>
                <div class="report-badge">Rapor</div>
            </div>
            <div class="report-card-body">
                <h3>Üye Raporu</h3>
                <p>Kayıtlı üyelerin bilgileri, şehir dağılımları ve üyelik istatistikleri.</p>
                <div class="report-meta">
                    <span><i class="fas fa-map-marker-alt"></i> Şehir Bazlı</span>
                    <span><i class="fas fa-list"></i> Tüm Liste</span>
                </div>
            </div>
            <div class="report-card-footer">
                <div class="btn-dropdown-wrapper">
                    <button class="btn-report btn-pdf" onclick="toggleDropdown(this)">
                        <i class="fas fa-file-pdf"></i> PDF <i class="fas fa-caret-down"></i>
                    </button>
                    <div class="dropdown-menu">
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "members", subType = "city", format = "pdf" })">
                            <i class="fas fa-city"></i> Şehir Bazlı Dağılım
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "members", subType = "all", format = "pdf" })">
                            <i class="fas fa-list"></i> Tüm Üyeler Listesi
                        </a>
                    </div>
                </div>
                <div class="btn-dropdown-wrapper">
                    <button class="btn-report btn-excel" onclick="toggleDropdown(this)">
                        <i class="fas fa-file-excel"></i> Excel <i class="fas fa-caret-down"></i>
                    </button>
                    <div class="dropdown-menu">
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "members", subType = "city", format = "excel" })">
                            <i class="fas fa-city"></i> Şehir Bazlı Dağılım
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "members", subType = "all", format = "excel" })">
                            <i class="fas fa-list"></i> Tüm Üyeler Listesi
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- 4. SATIŞ RAPORU -->
        <div class="report-card">
            <div class="report-card-header" style="background: linear-gradient(135deg, #43e97b, #38f9d7);">
                <div class="report-icon">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div class="report-badge">Rapor</div>
            </div>
            <div class="report-card-body">
                <h3>Satış Raporu</h3>
                <p>Aylık satış analizleri, kategori ve marka bazlı gelir dağılımları.</p>
                <div class="report-meta">
                    <span><i class="fas fa-calendar"></i> Aylık</span>
                    <span><i class="fas fa-folder"></i> Kategori</span>
                    <span><i class="fas fa-tag"></i> Marka</span>
                </div>
            </div>
            <div class="report-card-footer">
                <div class="btn-dropdown-wrapper">
                    <button class="btn-report btn-pdf" onclick="toggleDropdown(this)">
                        <i class="fas fa-file-pdf"></i> PDF <i class="fas fa-caret-down"></i>
                    </button>
                    <div class="dropdown-menu">
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "sales", subType = "monthly", format = "pdf" })">
                            <i class="fas fa-calendar-alt"></i> Aylık Satış Raporu
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "sales", subType = "category", format = "pdf" })">
                            <i class="fas fa-folder-open"></i> Kategori Bazlı
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "sales", subType = "brand", format = "pdf" })">
                            <i class="fas fa-tags"></i> Marka Bazlı
                        </a>
                    </div>
                </div>
                <div class="btn-dropdown-wrapper">
                    <button class="btn-report btn-excel" onclick="toggleDropdown(this)">
                        <i class="fas fa-file-excel"></i> Excel <i class="fas fa-caret-down"></i>
                    </button>
                    <div class="dropdown-menu">
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "sales", subType = "monthly", format = "excel" })">
                            <i class="fas fa-calendar-alt"></i> Aylık Satış Raporu
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "sales", subType = "category", format = "excel" })">
                            <i class="fas fa-folder-open"></i> Kategori Bazlı
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "sales", subType = "brand", format = "excel" })">
                            <i class="fas fa-tags"></i> Marka Bazlı
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- 5. STOK RAPORU -->
        <div class="report-card">
            <div class="report-card-header" style="background: linear-gradient(135deg, #fa709a, #fee140);">
                <div class="report-icon">
                    <i class="fas fa-warehouse"></i>
                </div>
                <div class="report-badge">Rapor</div>
            </div>
            <div class="report-card-body">
                <h3>Stok Raporu</h3>
                <p>Anlık stok durumları, kritik stok seviyeleri ve envanter durumu.</p>
                <div class="report-meta">
                    <span><i class="fas fa-exclamation-triangle"></i> Kritik Stok</span>
                    <span><i class="fas fa-boxes"></i> Tüm Stok</span>
                </div>
            </div>
            <div class="report-card-footer">
                <div class="btn-dropdown-wrapper">
                    <button class="btn-report btn-pdf" onclick="toggleDropdown(this)">
                        <i class="fas fa-file-pdf"></i> PDF <i class="fas fa-caret-down"></i>
                    </button>
                    <div class="dropdown-menu">
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "stock", subType = "critical", format = "pdf" })">
                            <i class="fas fa-exclamation-triangle"></i> Kritik Stok (≤10)
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "stock", subType = "all", format = "pdf" })">
                            <i class="fas fa-boxes"></i> Tüm Stok Durumu
                        </a>
                    </div>
                </div>
                <div class="btn-dropdown-wrapper">
                    <button class="btn-report btn-excel" onclick="toggleDropdown(this)">
                        <i class="fas fa-file-excel"></i> Excel <i class="fas fa-caret-down"></i>
                    </button>
                    <div class="dropdown-menu">
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "stock", subType = "critical", format = "excel" })">
                            <i class="fas fa-exclamation-triangle"></i> Kritik Stok (≤10)
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "stock", subType = "all", format = "excel" })">
                            <i class="fas fa-boxes"></i> Tüm Stok Durumu
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- 6. TEDARİKÇİ RAPORU -->
        <div class="report-card">
            <div class="report-card-header" style="background: linear-gradient(135deg, #a18cd1, #fbc2eb);">
                <div class="report-icon">
                    <i class="fas fa-truck"></i>
                </div>
                <div class="report-badge">Rapor</div>
            </div>
            <div class="report-card-body">
                <h3>Tedarikçi Raporu</h3>
                <p>Tedarikçi bilgileri, performans karşılaştırmaları ve ürün dağılımları.</p>
                <div class="report-meta">
                    <span><i class="fas fa-trophy"></i> Performans</span>
                    <span><i class="fas fa-list"></i> Tüm Liste</span>
                </div>
            </div>
            <div class="report-card-footer">
                <div class="btn-dropdown-wrapper">
                    <button class="btn-report btn-pdf" onclick="toggleDropdown(this)">
                        <i class="fas fa-file-pdf"></i> PDF <i class="fas fa-caret-down"></i>
                    </button>
                    <div class="dropdown-menu">
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "suppliers", subType = "performance", format = "pdf" })">
                            <i class="fas fa-chart-line"></i> Performans Raporu
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "suppliers", subType = "all", format = "pdf" })">
                            <i class="fas fa-list"></i> Tüm Tedarikçiler
                        </a>
                    </div>
                </div>
                <div class="btn-dropdown-wrapper">
                    <button class="btn-report btn-excel" onclick="toggleDropdown(this)">
                        <i class="fas fa-file-excel"></i> Excel <i class="fas fa-caret-down"></i>
                    </button>
                    <div class="dropdown-menu">
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "suppliers", subType = "performance", format = "excel" })">
                            <i class="fas fa-chart-line"></i> Performans Raporu
                        </a>
                        <a href="@Url.Action("GenerateReport", "Admin", new { reportType = "suppliers", subType = "all", format = "excel" })">
                            <i class="fas fa-list"></i> Tüm Tedarikçiler
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* ===== REPORTS PAGE ===== */
    .reports-page {
        padding: 10px 0;
    }

    .reports-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 35px;
        padding: 24px 28px;
        background: linear-gradient(135deg, #667eea10, #764ba210);
        border-radius: 16px;
        border: 1px solid #667eea20;
    }

    .reports-header-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.4rem;
        flex-shrink: 0;
    }

    .reports-header h2 {
        margin: 0;
        font-size: 1.4rem;
        font-weight: 700;
        color: #2d3748;
    }

    .reports-header p {
        margin: 4px 0 0;
        font-size: 0.9rem;
        color: #718096;
    }

    /* ===== GRID ===== */
    .reports-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    /* ===== REPORT CARD ===== */
    .report-card {
        background: #fff;
        border-radius: 16px;
        overflow: visible;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
        transition: all 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
        display: flex;
        flex-direction: column;
        border: 1px solid #f0f0f0;
    }

    .report-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    }

    .report-card-header {
        padding: 28px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
        border-radius: 16px 16px 0 0;
    }

    .report-card-header::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -30%;
        width: 120px;
        height: 120px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
    }

    .report-card-header::after {
        content: '';
        position: absolute;
        bottom: -40%;
        left: -20%;
        width: 80px;
        height: 80px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 50%;
    }

    .report-icon {
        width: 50px;
        height: 50px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.3rem;
        position: relative;
        z-index: 1;
        backdrop-filter: blur(10px);
    }

    .report-badge {
        background: rgba(255, 255, 255, 0.25);
        color: #fff;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        position: relative;
        z-index: 1;
    }

    .report-card-body {
        padding: 20px 24px;
        flex: 1;
    }

    .report-card-body h3 {
        margin: 0 0 8px;
        font-size: 1.1rem;
        font-weight: 700;
        color: #2d3748;
    }

    .report-card-body p {
        margin: 0 0 14px;
        font-size: 0.85rem;
        color: #718096;
        line-height: 1.6;
    }

    .report-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .report-meta span {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.72rem;
        color: #a0aec0;
        background: #f7f8fc;
        padding: 4px 10px;
        border-radius: 6px;
    }

    .report-meta span i {
        font-size: 0.7rem;
        color: #667eea;
    }

    /* ===== FOOTER & DROPDOWN ===== */
    .report-card-footer {
        padding: 14px 24px;
        border-top: 1px solid #f0f0f0;
        display: flex;
        gap: 10px;
        background: #fafbff;
        border-radius: 0 0 16px 16px;
    }

    .btn-dropdown-wrapper {
        flex: 1;
        position: relative;
    }

    .btn-report {
        width: 100%;
        padding: 10px 14px;
        border: none;
        border-radius: 10px;
        font-size: 0.82rem;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: all 0.3s ease;
        letter-spacing: 0.3px;
    }

    .btn-report .fa-caret-down {
        font-size: 0.7rem;
        margin-left: 2px;
        transition: transform 0.3s;
    }

    .btn-report.active .fa-caret-down {
        transform: rotate(180deg);
    }

    .btn-pdf {
        background: linear-gradient(135deg, #ff6b6b, #ee5a24);
        color: #fff;
        box-shadow: 0 3px 12px rgba(238, 90, 36, 0.25);
    }

    .btn-pdf:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(238, 90, 36, 0.35);
    }

    .btn-excel {
        background: linear-gradient(135deg, #2ecc71, #27ae60);
        color: #fff;
        box-shadow: 0 3px 12px rgba(39, 174, 96, 0.25);
    }

    .btn-excel:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(39, 174, 96, 0.35);
    }

    /* ===== DROPDOWN MENU ===== */
    .dropdown-menu {
        display: none;
        position: absolute;
        bottom: calc(100% + 8px);
        left: 0;
        right: 0;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
        border: 1px solid #e8e8e8;
        z-index: 1000;
        overflow: hidden;
        animation: dropdownSlide 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    .dropdown-menu.show {
        display: block;
    }

    .dropdown-menu a {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 11px 16px;
        color: #444;
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 500;
        transition: all 0.2s;
        border-bottom: 1px solid #f5f5f5;
    }

    .dropdown-menu a:last-child {
        border-bottom: none;
    }

    .dropdown-menu a:hover {
        background: linear-gradient(135deg, #667eea08, #764ba208);
        color: #667eea;
        padding-left: 20px;
    }

    .dropdown-menu a i {
        width: 18px;
        text-align: center;
        color: #667eea;
        font-size: 0.8rem;
    }

    @@keyframes dropdownSlide {
        from {
            opacity: 0;
            transform: translateY(8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 1200px) {
        .reports-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .reports-grid {
            grid-template-columns: 1fr;
        }

        .reports-header {
            flex-direction: column;
            text-align: center;
        }
    }
</style>

<script>
    function toggleDropdown(btn) {
        var wrapper = btn.parentElement;
        var menu = wrapper.querySelector('.dropdown-menu');
        var isOpen = menu.classList.contains('show');

        // Önce tüm açık dropdown'ları kapat
        document.querySelectorAll('.dropdown-menu.show').forEach(function (m) {
            m.classList.remove('show');
        });
        document.querySelectorAll('.btn-report.active').forEach(function (b) {
            b.classList.remove('active');
        });

        // Tıklanan dropdown'ı aç/kapat
        if (!isOpen) {
            menu.classList.add('show');
            btn.classList.add('active');
        }
    }

    // Sayfa üzerinde başka yere tıklayınca dropdown'ı kapat
    document.addEventListener('click', function (e) {
        if (!e.target.closest('.btn-dropdown-wrapper')) {
            document.querySelectorAll('.dropdown-menu.show').forEach(function (m) {
                m.classList.remove('show');
            });
            document.querySelectorAll('.btn-report.active').forEach(function (b) {
                b.classList.remove('active');
            });
        }
    });
</script>
