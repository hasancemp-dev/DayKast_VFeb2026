@model DayKast_VFeb2026.Models.Brands

@{
    ViewBag.Title = "Marka Sil";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3><i class="fas fa-exclamation-triangle"></i> Bu markayı silmek istediğinize emin misiniz?</h3>
<div>
    <h4>Marka Bilgileri</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Marka Adı</dt>
        <dd>@Html.DisplayFor(model => model.BrandName)</dd>

        <dt>Menşei</dt>
        <dd>@Html.DisplayFor(model => model.Origin)</dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-actions">
            <input type="submit" value="Sil" class="btn btn-danger" />
            @Html.ActionLink("İptal - Listeye Dön", "Index")
        </div>
    }
</div>
